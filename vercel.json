{
  "version": 2,
  "functions": {
    "api/analyse.js": {
      "runtime": "@vercel/node@5.x"
    },
    "api/contact.js": {
      "runtime": "@vercel/node@5.x"
    }
  },
  "routes": [
    {
      "src": "/api/analyse",
      "dest": "/api/analyse.js"
    },
    {
      "src": "/api/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
